{
  "name": "mcp-workbench-vscode",
  "displayName": "MCP Workbench",
  "description": "Run, inspect, and validate MCP servers from VS Code",
  "version": "0.2.0",
  "license": "Apache-2.0",
  "publisher": "raeseoklee",
  "repository": {
    "type": "git",
    "url": "https://github.com/raeseoklee/mcp-workbench-vscode.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "testing",
    "ai"
  ],
  "icon": "media/icon.png",
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "activationEvents": [
    "onLanguage:yaml",
    "workspaceContains:**/*.yaml",
    "workspaceContains:**/*.yml",
    "onCommand:mcpWorkbench.generateSpec"
  ],
  "contributes": {
    "commands": [
      {
        "command": "mcpWorkbench.runCurrentSpec",
        "title": "%command.runCurrentSpec.title%",
        "icon": "$(play)"
      },
      {
        "command": "mcpWorkbench.runWorkspaceSpecs",
        "title": "%command.runWorkspaceSpecs.title%",
        "icon": "$(run-all)"
      },
      {
        "command": "mcpWorkbench.updateSnapshots",
        "title": "%command.updateSnapshots.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "mcpWorkbench.refreshResults",
        "title": "%command.refreshResults.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "mcpWorkbench.generateSpec",
        "title": "%command.generateSpec.title%",
        "icon": "$(sparkle)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname == .yaml || resourceExtname == .yml",
          "command": "mcpWorkbench.runCurrentSpec",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "mcpWorkbench.generateSpec",
          "when": "view == mcpWorkbenchResults",
          "group": "navigation@1"
        },
        {
          "command": "mcpWorkbench.runWorkspaceSpecs",
          "when": "view == mcpWorkbenchResults",
          "group": "navigation@2"
        },
        {
          "command": "mcpWorkbench.refreshResults",
          "when": "view == mcpWorkbenchResults",
          "group": "navigation@3"
        }
      ],
      "commandPalette": [
        {
          "command": "mcpWorkbench.runCurrentSpec",
          "when": "editorLangId == yaml"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mcp-workbench",
          "title": "MCP Workbench",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "mcp-workbench": [
        {
          "id": "mcpWorkbenchResults",
          "name": "%view.testResults.name%",
          "icon": "$(beaker)",
          "contextualTitle": "MCP Workbench Test Results"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "mcpWorkbench.cliPath": {
          "type": "string",
          "default": "mcp-workbench",
          "description": "%config.cliPath.description%"
        },
        "mcpWorkbench.timeout": {
          "type": "number",
          "default": 30000,
          "description": "%config.timeout.description%"
        },
        "mcpWorkbench.specGlob": {
          "type": "string",
          "default": "**/*.{yaml,yml}",
          "description": "%config.specGlob.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "build:watch": "npm run build -- --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/l10n-dev": "^0.0.35",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
